{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-gemini-auth@latest"
  ],
  "mcp": {
    "devenv": {
      "type": "local",
      "command": [
        "devenv",
        "mcp"
      ],
      "environment": {
        "DEVENV_TUI": "false"
      },
      "enabled": true,
      "timeout": 20000
    }
  },
  "experimental": {
    "mcp_timeout": 20000
  }
}
